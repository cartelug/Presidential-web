---
import PageShell from '../components/PageShell.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<PageShell
  title="Downloads · Forty Years of Transformation"
  description="Download the record as a PDF, and the cleared media asset pack, for offline use and press."
  path="/downloads"
>
  <section class="page-section">
    <div class="wrap">
      <p class="eyebrow">Downloads</p>
      <h1>Take the record with you.</h1>
      <p class="lead">
        The full record, exported for offline reading, and the cleared
        photography behind it for press and archival use.
      </p>

      <ul class="download-list">
        <li>
          <div>
            <h2>The record — PDF</h2>
            <p>All ten chapters, the national ledger, and every cited source, paginated for reading or printing. 20 pages, 4.7 MB.</p>
          </div>
          <a class="btn-fill" href={`${base}/downloads/forty-years-of-transformation.pdf`} download>Download PDF</a>
        </li>
        <li>
          <div>
            <h2>Media asset pack</h2>
            <p>The cleared photography used across the record, plus the rights ledger naming each image's source, licence and credit. 787 KB.</p>
          </div>
          <a class="btn-fill" href={`${base}/downloads/forty-years-media-pack.zip`} download>Download media pack (.zip)</a>
        </li>
      </ul>

      <p class="fine-print">
        Two assets remain pending clearance — a 1986-era archival photograph and
        the official coat of arms — and are not included in this pack. See the
        <a href={`${base}/sources#assets`}>rights ledger</a> for status on every asset.
      </p>
    </div>
  </section>
</PageShell>

<style>
  .page-section {
    padding-block: var(--space-32) var(--space-24);
    background: var(--navy);
    min-height: 60vh;
  }
  .wrap {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  h1 {
    font-size: var(--text-h1);
    max-width: 20ch;
    margin: var(--space-4) 0 var(--space-6);
  }
  .lead {
    font-family: var(--font-display);
    font-size: var(--text-body-l);
    max-width: 60ch;
    color: var(--mist-bright);
  }
  .download-list {
    list-style: none;
    padding: 0;
    margin: var(--space-16) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .download-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    border-top: var(--border-gold-hairline);
    padding-top: var(--space-6);
  }
  .download-list h2 {
    font-size: var(--text-h3);
    color: var(--cream);
    margin: 0 0 var(--space-2);
  }
  .download-list p {
    max-width: 52ch;
    color: var(--mist-bright);
    margin: 0;
  }
  .btn-fill {
    display: inline-flex;
    flex-shrink: 0;
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--gold);
    color: var(--ink);
    text-decoration: none;
    border-radius: var(--radius-control);
    white-space: nowrap;
  }
  .btn-fill:hover {
    background: var(--gold-hi);
  }
  .fine-print {
    margin-top: var(--space-16);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--mist);
  }
  .fine-print a {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 700px) {
    .download-list li {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
