---
import { getCollection } from 'astro:content';
import PageShell from '../components/PageShell.astro';
import Seal from '../components/Seal.astro';
import ResponsivePicture from '../components/ResponsivePicture.astro';
import StatStrip from '../components/StatStrip.astro';
import EvidenceSpine from '../components/islands/EvidenceSpine';
import LedgerFigure from '../components/islands/LedgerFigure';
import EraTimeline from '../components/islands/EraTimeline';
import RegionMap from '../components/islands/RegionMap';
import VoicePanel from '../components/islands/VoicePanel';
import Filmstrip from '../components/islands/Filmstrip';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = (await getCollection('chapters')).sort((a, b) => a.data.order - b.data.order);
const byslug = Object.fromEntries(chapters.map((c) => [c.data.slug, c.data]));

const figures = await getCollection('figures');
const sourcesRaw = await getCollection('sources');
const sourceMap = Object.fromEntries(
  sourcesRaw.map((s) => [s.data.id, { number: s.data.number, source: s.data.source }])
);

const voicesRaw = (await getCollection('voices')).sort((a, b) => a.data.order - b.data.order);
const voices = voicesRaw.map((v) => ({
  id: v.id,
  name: v.data.name,
  role: v.data.role,
  place: v.data.place,
  quote: v.body?.trim() ?? '',
}));

const achievementsRaw = (await getCollection('achievements')).sort((a, b) => a.data.order - b.data.order);
const journeyErasRaw = (await getCollection('journeyEras')).sort((a, b) => a.data.order - b.data.order);
const regionsRaw = await getCollection('regions');
const filmFramesRaw = (await getCollection('filmFrames')).sort((a, b) => a.data.order - b.data.order);
const nextThemes = (await getCollection('nextThemes')).sort((a, b) => a.data.order - b.data.order);

type ImageMeta = { src: string; srcMobile: string; width: number; height: number; alt: string };
const IMAGES: Record<string, ImageMeta> = {
  'fig-karuma': { src: `${base}/images/fig-karuma.webp`, srcMobile: `${base}/images/fig-karuma-m.webp`, width: 1100, height: 733, alt: 'Aerial view of Karuma dam on the Nile' },
  'fig-upe': { src: `${base}/images/fig-upe.webp`, srcMobile: `${base}/images/fig-upe-m.webp`, width: 1280, height: 853, alt: 'Students in a classroom during a lesson' },
  'fig-expressway': { src: `${base}/images/fig-expressway.webp`, srcMobile: `${base}/images/fig-expressway-m.webp`, width: 900, height: 601, alt: 'Kampala–Entebbe Expressway interchange from above' },
  'fig-coffee': { src: `${base}/images/fig-coffee.webp`, srcMobile: `${base}/images/fig-coffee-m.webp`, width: 780, height: 405, alt: 'Coffee beans and ripening coffee cherries' },
  'fig-health': { src: `${base}/images/fig-health.webp`, srcMobile: `${base}/images/fig-health-m.webp`, width: 1024, height: 683, alt: 'Health workers attending to newborns in a modern clinic' },
  'bg-inheritance': { src: `${base}/images/bg-inheritance.webp`, srcMobile: `${base}/images/bg-inheritance.webp`, width: 1200, height: 1389, alt: 'The President greeting citizens outdoors' },
};

const achievements = achievementsRaw.map((a) => ({ ...a.data, img: IMAGES[a.data.image] }));
const journeyEras = journeyErasRaw.map((e) => e.data);
const filmFrames = filmFramesRaw.map((f) => {
  const img = IMAGES[f.data.image];
  return { id: f.id, frame: f.data.frame, place: f.data.place, year: f.data.year, caption: f.data.caption, src: img.src, srcMobile: img.srcMobile, alt: img.alt };
});

const sectionIds = ['opening', 'inheritance', 'ledger', 'journey', 'achievements', 'regions', 'voices', 'pictures', 'next', 'record'];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'GovernmentOrganization',
    name: 'Office of the President, Republic of Uganda',
    url: 'https://cartelug.github.io/Presidential-web/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: 'Forty Years of Transformation · Republic of Uganda · 1986–2026',
    description: 'The official 40-year legacy record of the Republic of Uganda, 1986–2026.',
    about: 'Republic of Uganda national development, 1986–2026',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cartelug.github.io/Presidential-web/' },
    ],
  },
];
---

<PageShell
  title="Forty Years of Transformation · Republic of Uganda · 1986–2026"
  description="From a nation in ruins to a nation on the rise: the official 40-year legacy record of the Republic of Uganda, 1986–2026."
  path="/"
  jsonLd={jsonLd}
>
  <EvidenceSpine client:load sectionIds={sectionIds} />

  <!-- 01 · OPENING -->
  <section id="opening" class="chapter chapter-opening" aria-labelledby="opening-title">
    <div class="grain-overlay" aria-hidden="true"></div>
    <div class="opening-inner">
      <p class="eyebrow">{byslug.opening.eyebrow}</p>
      <h1 id="opening-title" data-split-text>{byslug.opening.title}</h1>
      <p class="opening-subtitle">{byslug.opening.subtitle}</p>
      <p class="opening-standfirst">{byslug.opening.standfirst}</p>
      <a class="btn-fill" href="#ledger">{byslug.opening.cta}</a>
    </div>
    <img
      class="opening-portrait"
      src={`${base}/images/cut-president-hero.webp`}
      alt="The President of the Republic of Uganda"
      width="697"
      height="794"
      fetchpriority="high"
      decoding="async"
    />
    <div class="opening-stats">
      <StatStrip figures={figures} sourceMap={sourceMap} />
    </div>
  </section>

  <!-- 02 · INHERITANCE -->
  <section id="inheritance" class="chapter chapter-inheritance" aria-labelledby="inheritance-title" data-reveal-group>
    <div class="wrap">
      <p class="eyebrow" data-reveal>{byslug.inheritance.eyebrow}</p>
      <h2 id="inheritance-title" data-reveal>{byslug.inheritance.title}</h2>
      <p class="lead" data-reveal>{byslug.inheritance.standfirst}</p>
      <figure class="archive-plate" data-reveal>
        <div class="archive-placeholder">
          <span class="mono">FRAME 000 · UGANDA · 1986</span>
          <span class="archive-pending">Archival photograph pending clearance</span>
        </div>
      </figure>
      <ul class="inheritance-data">
        <li><b class="data-numeral">$330</b><span>GDP per capita</span></li>
        <li><b class="data-numeral">60 MW</b><span>Electricity generation</span></li>
        <li><b class="data-numeral">56%</b><span>Poverty rate</span></li>
      </ul>
    </div>
  </section>

  <!-- 03 · LEDGER -->
  <section id="ledger" class="chapter chapter-ledger" aria-labelledby="ledger-title">
    <div class="wrap">
      <p class="eyebrow">{byslug.ledger.eyebrow}</p>
      <h2 id="ledger-title">{byslug.ledger.title}</h2>
      <div class="ledger-grid">
        {figures.map((f) => (
          <LedgerFigure
            client:visible
            label={f.data.label}
            value1986={f.data.value1986}
            value2026={f.data.value2026}
            value2026Numeric={f.data.value2026Numeric ?? 0}
            unit={f.data.unit ?? ''}
            sourceHref={f.data.sourceId ? `${base}/sources#src-${sourceMap[f.data.sourceId]?.number}` : `${base}/sources`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 04 · JOURNEY -->
  <section id="journey" class="chapter chapter-journey" aria-labelledby="journey-title">
    <div class="wrap wrap-header">
      <p class="eyebrow">{byslug.journey.eyebrow}</p>
      <h2 id="journey-title">{byslug.journey.title}</h2>
    </div>
    <EraTimeline client:visible eras={journeyEras} />
  </section>

  <!-- 05 · ACHIEVEMENTS -->
  <section id="achievements" class="chapter chapter-achievements" aria-labelledby="achievements-title">
    <div class="wrap">
      <p class="eyebrow">{byslug.achievements.eyebrow}</p>
      <h2 id="achievements-title">{byslug.achievements.title}</h2>
    </div>
    <div class="achievements-bands">
      {achievements.map((a) => (
        <article class={`achievement-band align-${a.align}`} data-reveal-group data-speed-root>
          <ResponsivePicture
            class="achievement-image"
            data-reveal
            data-speed="0.08"
            name={a.image}
            alt={a.img.alt}
            sizes="(max-width: 900px) 92vw, 45vw"
            loading="lazy"
          />
          <div class="achievement-copy" data-reveal>
            <p class="eyebrow">{a.pillar}</p>
            <p class="achievement-claim">{a.claim}</p>
            <ul class="achievement-facts">
              {a.facts.map((fact) => <li>{fact}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- 06 · REGIONS -->
  <section id="regions" class="chapter chapter-regions" aria-labelledby="regions-title">
    <div class="wrap">
      <p class="eyebrow">{byslug.regions.eyebrow}</p>
      <h2 id="regions-title">{byslug.regions.title}</h2>
      <p class="lead">{byslug.regions.standfirst}</p>
    </div>
    <RegionMap client:visible regions={regionsRaw.map((r) => r.data)} />
  </section>

  <!-- 07 · VOICES -->
  <section id="voices" class="chapter chapter-voices" aria-labelledby="voices-title">
    <div class="wrap">
      <p class="eyebrow">{byslug.voices.eyebrow}</p>
      <h2 id="voices-title">{byslug.voices.title}</h2>
      <VoicePanel client:visible voices={voices} />
      <p class="voices-note">Representative sample testimonies — first names only.</p>
    </div>
  </section>

  <!-- 08 · IN PICTURES -->
  <section id="pictures" class="chapter chapter-pictures" aria-labelledby="pictures-title">
    <div class="wrap wrap-header">
      <p class="eyebrow">{byslug.pictures.eyebrow}</p>
      <h2 id="pictures-title">{byslug.pictures.title}</h2>
    </div>
    <Filmstrip client:visible frames={filmFrames} />
  </section>

  <!-- 09 · WHAT'S NEXT -->
  <section id="next" class="chapter chapter-next" aria-labelledby="next-title" data-reveal-group>
    <div class="wrap">
      <p class="eyebrow" data-reveal>{byslug.next.eyebrow}</p>
      <h2 id="next-title" data-reveal>{byslug.next.title}</h2>
      <p class="lead" data-reveal>{byslug.next.standfirst}</p>
      <ul class="next-themes">
        {nextThemes.map((t) => (
          <li data-reveal>
            <b>{t.data.theme}</b>
            <span>{t.data.note}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 10 · THE RECORD CONTINUES -->
  <section id="record" class="chapter chapter-closing" aria-labelledby="closing-title">
    <div class="wrap">
      <Seal class="closing-seal" variant="light" />
      <h2 id="closing-title">{byslug.record.title}</h2>
      <a class="btn-ghost" href="#opening">{byslug.record.cta}</a>
    </div>
  </section>
</PageShell>

<script>
  import { initChapterSpy } from '../lib/chapter-spy';
  import { gsap, prefersReducedMotion, SplitText } from '../lib/motion';

  initChapterSpy(['opening', 'inheritance', 'ledger', 'journey', 'achievements', 'regions', 'voices', 'pictures', 'next', 'record']);

  const heading = document.querySelector<HTMLElement>('[data-split-text]');
  if (heading && !prefersReducedMotion()) {
    const split = new SplitText(heading, { type: 'words' });
    gsap.from(split.words, {
      yPercent: 100,
      opacity: 0,
      duration: 1.1,
      ease: 'cubic-bezier(0.16, 1, 0.3, 1)',
      stagger: 0.08,
    });
  }

  const seal = document.querySelector<SVGPathElement>('[data-seal] .seal-arc');
  if (seal) {
    if (prefersReducedMotion()) {
      seal.style.strokeDashoffset = '0';
    } else {
      import('../lib/motion').then(({ ScrollTrigger }) => {
        ScrollTrigger.create({
          trigger: seal,
          start: 'top 80%',
          once: true,
          onEnter: () => gsap.to(seal, { strokeDashoffset: 0, duration: 1.1, ease: 'power2.out' }),
        });
      });
    }
  }
</script>

<style>
  .chapter {
    position: relative;
    padding-block: var(--section-pad-mobile);
  }
  @media (min-width: 768px) {
    .chapter {
      padding-block: var(--section-pad-tablet);
    }
  }
  @media (min-width: 1200px) {
    .chapter {
      padding-block: var(--section-pad-desktop);
    }
  }
  .wrap {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  .wrap-header {
    margin-bottom: var(--space-12);
  }
  .lead {
    font-family: var(--font-display);
    font-size: var(--text-body-l);
    color: var(--mist-bright);
    max-width: 46ch;
  }

  /* 01 Opening */
  .chapter-opening {
    min-height: 100dvh;
    display: grid;
    grid-template-columns: 1fr;
    align-items: end;
    background: var(--navy);
    overflow: hidden;
  }
  .opening-inner {
    grid-row: 1;
    position: relative;
    z-index: 1;
    padding-inline: var(--page-margin);
    padding-top: var(--space-48);
    max-width: min(56ch, 46vw);
  }
  .opening-inner h1 {
    font-size: var(--text-display-xl);
    line-height: var(--leading-display-xl);
    font-weight: var(--weight-display-xl);
    margin: var(--space-4) 0;
    overflow-wrap: break-word;
  }
  @media (max-width: 420px) {
    .opening-inner h1 {
      /* "Transformation" alone overflows a 375px column at the 3.25rem clamp
         floor; scale purely by viewport width below the smallest breakpoint. */
      font-size: clamp(2.25rem, 11vw, 7rem);
    }
  }
  .opening-subtitle {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mist);
  }
  .opening-standfirst {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2.2vw, 1.45rem);
    color: var(--mist-bright);
    margin: var(--space-6) 0;
    max-width: 44ch;
  }
  .btn-fill {
    display: inline-flex;
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--gold);
    color: var(--ink);
    text-decoration: none;
    border-radius: var(--radius-control);
  }
  .btn-fill:hover {
    background: var(--gold-hi);
  }
  .btn-ghost {
    display: inline-flex;
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--ink-soft);
    color: var(--ink);
    text-decoration: none;
    margin-top: var(--space-8);
  }
  .btn-ghost:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--cream);
  }
  .opening-portrait {
    position: absolute;
    z-index: 0;
    right: var(--page-margin);
    bottom: 0;
    width: clamp(240px, 30vw, 460px);
    height: auto;
    max-height: 78%;
    object-fit: contain;
    object-position: bottom;
    opacity: 0.94;
  }
  .opening-stats {
    position: relative;
    z-index: 1;
    padding: var(--space-12) var(--page-margin) var(--space-16);
    background: linear-gradient(to top, var(--navy) 40%, transparent);
  }

  @media (max-width: 900px) {
    .opening-inner {
      max-width: 100%;
      padding-top: var(--space-32);
    }
    .opening-portrait {
      width: 62vw;
      max-height: 46%;
      opacity: 0.55;
      z-index: 0;
    }
  }

  /* 02 Inheritance */
  .chapter-inheritance {
    background: var(--navy);
  }
  .chapter-inheritance h2 {
    font-size: var(--text-h1);
    margin: var(--space-4) 0 var(--space-6);
    max-width: 16ch;
  }
  .archive-plate {
    margin: var(--space-8) 0;
    border: var(--border-hairline);
    background: var(--obsidian);
  }
  .archive-placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }
  .archive-placeholder .mono {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--gold);
  }
  .archive-pending {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--mist);
  }
  .inheritance-data {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin: var(--space-8) 0 0;
  }
  .inheritance-data li {
    border-top: var(--border-gold-hairline);
    padding-top: var(--space-3);
  }
  .inheritance-data b {
    display: block;
    font-size: 1.5rem;
    color: var(--gold-hi);
  }
  .inheritance-data span {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mist);
  }

  /* 03 Ledger — the cream chapter */
  .chapter-ledger {
    background: var(--cream);
    color: var(--ink);
  }
  .chapter-ledger .eyebrow {
    color: var(--ink-soft);
  }
  .chapter-ledger .eyebrow::before {
    background: var(--gold-deep);
  }
  .chapter-ledger h2 {
    color: var(--ink);
    font-size: var(--text-h1);
    max-width: 20ch;
  }
  .ledger-grid {
    margin-top: var(--space-12);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-8);
  }
  :global(.ledger-figure) {
    display: block;
    text-decoration: none;
    border-top: 1px solid rgb(from var(--gold-deep) r g b / 30%);
    padding-top: var(--space-3);
  }
  :global(.ledger-eyebrow) {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--ink-soft);
  }
  :global(.ledger-num) {
    display: block;
    font-size: var(--text-data-xl);
    color: var(--ink);
    line-height: 1;
    margin: var(--space-2) 0;
  }
  :global(.ledger-label) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  /* 04 Journey */
  .chapter-journey {
    background: var(--navy);
    padding-bottom: 0;
  }
  .chapter-journey h2 {
    font-size: var(--text-h1);
  }
  :global(.era-timeline) {
    height: 100dvh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  :global(.era-track) {
    display: flex;
    will-change: transform;
  }
  :global(.era-slide) {
    flex: 0 0 100vw;
    padding-inline: var(--page-margin);
  }
  :global(.era-year) {
    font-size: clamp(4rem, 12vw, 9rem);
    color: var(--gold-hi);
    line-height: 0.8;
  }
  :global(.era-label) {
    font-size: var(--text-h1);
    margin-top: var(--space-4);
  }
  :global(.era-note) {
    max-width: 42ch;
    color: var(--mist-bright);
    margin-top: var(--space-4);
  }

  /* 05 Achievements */
  .chapter-achievements {
    background: var(--navy);
  }
  .achievements-bands {
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
  }
  .achievement-band {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .achievement-band.align-right {
    direction: rtl;
  }
  .achievement-band.align-right .achievement-copy {
    direction: ltr;
  }
  .achievement-band picture {
    display: block;
    overflow: hidden;
    border-radius: 4px;
  }
  .achievement-band img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    /* lerped parallax (src/lib/parallax.ts) drives --py; the 1.08 overscan
       gives the translate headroom so it never uncovers the picture's edge.
       Falls back to translateY(0) so the image sits still until JS boots
       or under reduced motion. */
    transform: scale(1.12) translateY(var(--py, 0px));
  }
  .achievement-claim {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--cream);
    margin: var(--space-3) 0 var(--space-6);
  }
  .achievement-facts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .achievement-facts li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--mist-bright);
    padding-left: var(--space-4);
    position: relative;
  }
  .achievement-facts li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 8px;
    height: 1px;
    background: var(--gold);
  }
  @media (max-width: 900px) {
    .achievement-band,
    .achievement-band.align-right {
      grid-template-columns: 1fr;
      direction: ltr;
    }
  }

  /* 06 Regions */
  .chapter-regions {
    background: var(--navy);
  }
  :global(.region-map) {
    max-width: var(--content-max);
    margin: var(--space-12) auto 0;
    padding-inline: var(--page-margin);
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-8);
  }
  :global(.region-map-svg) {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
  }
  :global(.region-node) {
    cursor: pointer;
  }
  :global(.region-node:focus-visible circle) {
    outline: 2px solid var(--gold-hi);
    outline-offset: 3px;
  }
  :global(.region-panel) {
    border-top: var(--border-gold-hairline);
    padding-top: var(--space-4);
    min-height: 8em;
  }
  :global(.region-story-placeholder) {
    color: var(--mist);
  }
  :global(.region-fallback-list) {
