---
interface Props {
  class?: string;
  variant?: 'dark' | 'light';
}
const { class: className = '', variant = 'dark' } = Astro.props;
---

<!--
  The 40-year seal — a generated emblem, not the official coat of arms.
  Per §4 hard rule: no fabricated state seal. Swap for the cleared crest
  file (see src/content/asset-ledger.json → crest-pending) when supplied.
-->
<svg
  class={`seal seal-${variant} ${className}`}
  viewBox="0 0 200 200"
  role="img"
  aria-label="Forty-year seal, Republic of Uganda, 1986 to 2026"
  data-seal
>
  <circle class="seal-ring-outer" cx="100" cy="100" r="94" fill="none" stroke="var(--gold)" stroke-width="1.25" />
  <circle class="seal-ring-inner" cx="100" cy="100" r="80" fill="none" stroke="var(--gold)" stroke-width="0.75" opacity="0.6" />
  <text class="seal-year seal-year-start" x="100" y="46" text-anchor="middle">1986</text>
  <text class="seal-year seal-year-end" x="100" y="168" text-anchor="middle">2026</text>
  <text class="seal-num" x="100" y="122" text-anchor="middle">40</text>
  <path
    class="seal-arc"
    d="M 100 20 A 80 80 0 0 1 180 100"
    fill="none"
    stroke="var(--gold-hi)"
    stroke-width="1.5"
    pathLength="100"
  />
</svg>

<style>
  .seal {
    width: clamp(120px, 20vw, 220px);
    height: auto;
    overflow: visible;
  }
  .seal-year {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    fill: var(--mist-bright);
  }
  .seal-num {
    font-family: var(--font-display);
    font-size: 44px;
    fill: var(--cream);
  }
  .seal-light .seal-year {
    fill: var(--ink-soft);
  }
  .seal-light .seal-num {
    fill: var(--ink);
  }
  .seal-arc {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
</style>
