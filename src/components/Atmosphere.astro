---
/*
  Persistent living background. Mounted as the first child of <body> in
  PageShell so all pages inherit it. `transition:persist` keeps the canvas
  alive across Astro view transitions (no re-boot / no flash on nav).

  The .atmosphere carries a static CSS gradient that is the whole experience
  under prefers-reduced-motion (where atmosphere.ts never starts the canvas).
*/
---

<div class="atmosphere" aria-hidden="true" data-atmosphere transition:persist>
  <canvas class="atmosphere__canvas"></canvas>
  <div class="atmosphere__grain grain-overlay"></div>
</div>

<style>
  .atmosphere {
    position: fixed;
    inset: 0;
    z-index: var(--z-atmosphere);
    pointer-events: none;
    /* Static fallback + pre-JS paint: a warm dawn field, never a flat fill. */
    background:
      radial-gradient(
        120% 82% at 50% 8%,
        color-mix(in oklch, var(--gold) 9%, var(--navy)),
        var(--navy) 46%,
        var(--obsidian) 100%
      );
  }

  .atmosphere__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .atmosphere__grain {
    position: absolute;
    inset: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    /* Canvas is hidden by atmosphere.ts; the CSS gradient above stands in. */
    .atmosphere__canvas {
      display: none;
    }
  }
</style>
