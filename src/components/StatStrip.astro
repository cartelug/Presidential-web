---
import type { CollectionEntry } from 'astro:content';

interface Props {
  figures: CollectionEntry<'figures'>[];
  sourceMap: Record<string, { number: number; source: string }>;
}
const { figures, sourceMap } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<ul class="stat-strip" data-reveal-group>
  {figures.map((f) => {
    const src = f.data.sourceId ? sourceMap[f.data.sourceId] : null;
    return (
      <li data-reveal>
        <a class="stat" href={src ? `${base}/sources#src-${src.number}` : `${base}/sources`}>
          <span class="stat-value data-numeral">{f.data.value2026}</span>
          <span class="stat-label">{f.data.label}</span>
          {src && <span class="stat-source">Source: {src.source}</span>}
        </a>
      </li>
    );
  })}
</ul>

<style>
  .stat-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-6);
  }
  .stat {
    display: block;
    text-decoration: none;
    padding-top: var(--space-4);
    border-top: var(--border-gold-hairline);
    position: relative;
  }
  .stat-value {
    display: block;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    color: var(--gold-hi);
    font-weight: 500;
  }
  .stat-label {
    display: block;
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mist-bright);
  }
  .stat-source {
    position: absolute;
    left: 0;
    bottom: 100%;
    margin-bottom: var(--space-2);
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--mist);
    white-space: nowrap;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity var(--dur-fast) var(--ease-standard), transform var(--dur-fast) var(--ease-standard);
    pointer-events: none;
  }
  .stat:hover .stat-source,
  .stat:focus-visible .stat-source {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    .stat-strip {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
