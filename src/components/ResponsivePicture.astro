---
import manifest from '../data/image-manifest.json';

interface Props {
  name: string; // basename without extension, e.g. "fig-karuma"
  alt: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  [key: string]: unknown;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { name, alt, sizes = '100vw', loading = 'lazy', fetchpriority = 'auto', class: className = '', ...rest } = Astro.props;

const entry = (manifest as Record<string, { widths: number[]; nativeWidth: number; nativeHeight: number; dataUri: string }>)[name];
const widths = entry?.widths ?? [];
const srcset = (ext: string) => widths.map((w) => `${base}/images/${name}-${w}.${ext} ${w}w`).join(', ');
const fallbackWidth = widths[widths.length - 1] ?? entry?.nativeWidth ?? 960;
---

<picture>
  <source type="image/avif" srcset={srcset('avif')} sizes={sizes} />
  <source type="image/webp" srcset={srcset('webp')} sizes={sizes} />
  <img
    {...rest}
    class={className}
    src={`${base}/images/${name}-${fallbackWidth}.jpg`}
    srcset={srcset('jpg')}
    sizes={sizes}
    alt={alt}
    width={entry?.nativeWidth}
    height={entry?.nativeHeight}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    style={`background-image:url(${entry?.dataUri}); background-size:cover;`}
  />
</picture>
