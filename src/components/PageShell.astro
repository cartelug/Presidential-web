---
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';
import '../styles/global.css';
import frauncesUrl from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url';
import schibstedUrl from '@fontsource/schibsted-grotesk/files/schibsted-grotesk-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>[];
}

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // e.g. '/Presidential-web'

const {
  title,
  description,
  path,
  ogImage = `${base}/images/og-cover.jpg`,
  jsonLd = [],
} = Astro.props;

const canonical = new URL(`${base}${path}`, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='4' fill='%230B0E14'/%3E%3Ccircle cx='32' cy='32' r='22' fill='none' stroke='%23C9A227' stroke-width='2.5'/%3E%3Ctext x='32' y='39' font-family='Georgia,serif' font-size='20' fill='%23E4C368' text-anchor='middle'%3E40%3C/text%3E%3C/svg%3E" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Forty Years of Transformation · Republic of Uganda" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#0B0E14" />
    <meta name="color-scheme" content="dark" />

    {jsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

    <link rel="preload" as="font" type="font/woff2" href={frauncesUrl} crossorigin fetchpriority="high" />
    <link rel="preload" as="font" type="font/woff2" href={schibstedUrl} crossorigin fetchpriority="high" />
  </head>
  <body class="no-js">
    <a class="skip-link" href="#main">Skip to content</a>

    <SiteHeader />

    <main id="main">
      <slot />
    </main>

    <SiteFooter />

    <script>
      document.body.classList.remove('no-js');
      document.body.classList.add('js');

      import('../lib/motion').then(({ initMotion }) => initMotion());
      import('../lib/reveal').then(({ initReveals }) => initReveals());
    </script>
  </body>
</html>
