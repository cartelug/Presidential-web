---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="consent-banner" id="consentBanner" hidden role="dialog" aria-label="Cookie and analytics consent" aria-live="polite">
  <p>
    This record uses no third-party trackers. With your consent, it records
    anonymous, self-hosted visit counts to understand which chapters are
    read — no cookies, no personal data. See the
    <a href={`${base}/accessibility#privacy`}>privacy note</a>.
  </p>
  <div class="consent-actions">
    <button type="button" id="consentDecline">Decline</button>
    <button type="button" id="consentAccept" class="consent-accept">Accept</button>
  </div>
</div>

<style>
  .consent-banner {
    position: fixed;
    left: var(--space-4);
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: var(--z-overlay);
    max-width: 640px;
    margin-inline: auto;
    background: var(--navy-raised);
    border: var(--border-hairline);
    padding: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-6);
  }
  .consent-banner p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--mist-bright);
    flex: 1 1 320px;
  }
  .consent-banner a {
    color: var(--gold);
  }
  .consent-actions {
    display: flex;
    gap: var(--space-3);
  }
  .consent-actions button {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-3) var(--space-4);
    border: var(--border-hairline);
    background: none;
    color: var(--mist-bright);
    border-radius: var(--radius-control);
  }
  .consent-accept {
    background: var(--gold);
    color: var(--ink);
    border-color: var(--gold);
  }
</style>

<script>
  import { getConsent, setConsent } from '../lib/analytics';

  const banner = document.getElementById('consentBanner');
  if (banner && !getConsent()) {
    banner.hidden = false;
  }

  document.getElementById('consentAccept')?.addEventListener('click', () => {
    setConsent('accepted');
    if (banner) banner.hidden = true;
  });
  document.getElementById('consentDecline')?.addEventListener('click', () => {
    setConsent('declined');
    if (banner) banner.hidden = true;
  });
</script>
