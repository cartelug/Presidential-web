---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const chapters = [
  { href: `${base}/#opening`, label: 'Opening' },
  { href: `${base}/#inheritance`, label: 'Inheritance' },
  { href: `${base}/#ledger`, label: 'Ledger' },
  { href: `${base}/#journey`, label: 'Journey' },
  { href: `${base}/#achievements`, label: 'Achievements' },
  { href: `${base}/#regions`, label: 'Regions' },
  { href: `${base}/#voices`, label: 'Voices' },
  { href: `${base}/#pictures`, label: 'Pictures' },
  { href: `${base}/#next`, label: 'Next' },
  { href: `${base}/#record`, label: 'Record' },
];
---

<header class="site-header" id="siteHeader" data-header>
  <div class="site-header-inner">
    <a class="lockup" href={`${base}/`}>
      <span class="lockup-mono">Republic of Uganda · 1986–2026</span>
      <span class="lockup-title">Forty Years of Transformation</span>
    </a>

    <nav class="chapter-nav" aria-label="Chapters" data-chapter-nav>
      <ol>
        {chapters.map((c) => (
          <li>
            <a href={c.href}>{c.label}</a>
          </li>
        ))}
      </ol>
    </nav>

    <div class="header-actions">
      <a class="header-link" href={`${base}/sources`}>Sources</a>
      <a class="btn-cta" href={`${base}/#ledger`}>Explore the Record</a>
    </div>

    <button class="menu-btn" id="menuBtn" aria-expanded="false" aria-controls="menuOverlay" aria-label="Open chapter menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="menu-overlay" id="menuOverlay" hidden>
  <nav aria-label="Chapters (mobile)">
    <ol>
      {chapters.map((c) => (
        <li><a href={c.href}>{c.label}</a></li>
      ))}
      <li><a href={`${base}/sources`}>Sources</a></li>
      <li><a href={`${base}/accessibility`}>Accessibility</a></li>
      <li><a href={`${base}/downloads`}>Downloads</a></li>
    </ol>
  </nav>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-chapter-nav);
    background: color-mix(in oklab, var(--navy) 88%, transparent);
    border-bottom: var(--border-hairline);
    backdrop-filter: blur(8px);
    transition: padding var(--dur-fast) var(--ease-standard);
  }
  .site-header[data-condensed] {
    padding-block: 2px;
  }
  .site-header-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    padding-block: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .lockup {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    margin-right: auto;
  }
  .lockup-mono {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mist);
  }
  .lockup-title {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--cream);
  }
  .chapter-nav ol {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
    white-space: nowrap;
  }
  .chapter-nav a {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--mist);
    padding-block: var(--space-2);
  }
  .chapter-nav a:hover,
  .chapter-nav a[aria-current='true'] {
    color: var(--gold-hi);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .header-link {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--mist-bright);
  }
  .btn-cta {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    background: var(--gold);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-control);
    white-space: nowrap;
  }
  .btn-cta:hover {
    background: var(--gold-hi);
  }
  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: 0;
    padding: var(--space-2);
    margin-left: auto;
  }
  .menu-btn span {
    width: 22px;
    height: 1.5px;
    background: var(--gold);
  }
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: var(--obsidian);
    padding: var(--space-24) var(--page-margin);
  }
  .menu-overlay ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .menu-overlay a {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--cream);
    text-decoration: none;
  }

  @media (max-width: 1180px) {
    .chapter-nav,
    .header-actions {
      display: none;
    }
    .menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const menuBtn = document.getElementById('menuBtn');
  const overlay = document.getElementById('menuOverlay');

  if (header) {
    const onScroll = () => {
      if (window.scrollY > 40) header.setAttribute('data-condensed', '');
      else header.removeAttribute('data-condensed');
    };
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  if (menuBtn && overlay) {
    menuBtn.addEventListener('click', () => {
      const open = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!open));
      overlay.hidden = open;
    });
    overlay.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        menuBtn.setAttribute('aria-expanded', 'false');
        overlay.hidden = true;
      })
    );
  }
</script>
